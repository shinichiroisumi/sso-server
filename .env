PORT=3000
AUTH_MODE=ad
AD_URL=ldaps://your-ad-server:636
AD_BASE_DN=dc=yourdomain,dc=com
AD_DOMAIN=yourdomain.local
AD_BIND_USER=cn=service_account,cn=Users,dc=yourdomain,dc=com
AD_BIND_PASSWORD=your_service_password
JWT_SECRET=your-super-secret-jwt-key-change-this
NODE_ENV=production
ALLOWED_ORIGINS=http://app1.yourdomain.com,http://app2.yourdomain.com
ALLOWED_APPS=test-app